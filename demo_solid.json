{
  "design_params": {
    "name": "demo_design",
    "params": {
      "world_width": { "type": "fix16", "value": 1280 },
      "world_height": { "type": "fix16", "value": 1024 },
      "display_width": { "type": "u32", "value": 1280 },
      "display_height": { "type": "u32", "value": 1024 },
      "max_speed": { "type": "fix16", "value": 500 },
      "player_health": { "type": "u32", "value": 100 },
      "enemy_health": { "type": "u32", "value": 30 },
      "boss_health": { "type": "u32", "value": 200 },
      "bullet_damage": { "type": "u32", "value": 10 },
      "bullet_health": { "type": "u32", "value": 1 },
      "max_entities": { "type": "u32", "value": 8 },
      "player_size": { "type": "fix16", "value": 16 },
      "max_delta_time": { "type": "fix16", "value": 0.05 }
    },
    "design_invariants": []
  },
  "schemas": [
    {
      "name": "EntityBuffer",
      "struct": {
        "position": {
          "type": "fix16x2",
          "range": [[0, "$world_width"], [0, "$world_height"]]
        },
        "velocity": {
          "type": "fix16x2",
          "range": [["$-max_speed", "$max_speed"], ["$-max_speed", "$max_speed"]]
        },
        "size": { "type": "i32", "range": [0, "$player_size"] },
        "health": { "type": "u32", "range": [0, "$boss_health"] },
        "max_health": { "type": "u32", "range": [0, "$boss_health"] },
        "entity_type": { "type": "u32", "enum": [0, 1, 2, 3] },
        "damage": { "type": "u32", "range": [0, "$bullet_damage"] },
        "alive": { "type": "u32", "enum": [0, 1] }
      },
      "capacity": "$max_entities",
      "buffer_category": "state",
      "invariants": ["health <= max_health"]
    },
    {
      "name": "InputBuffer",
      "struct": {
        "keys_down": { "type": "u32", "range": [0, 31] },
        "mouse_x": { "type": "i32", "range": [0, "$world_width"] },
        "mouse_y": { "type": "i32", "range": [0, "$world_height"] },
        "mouse_buttons": { "type": "u32", "range": [0, 7] }
      },
      "capacity": 1,
      "buffer_category": "input"
    },
    {
      "name": "GlobalsBuffer",
      "struct": {
        "frame_number": { "type": "u32" },
        "delta_time": { "type": "i32", "range": [0, 3277] },
        "world_width": { "type": "i32", "value": "$world_width" },
        "world_height": { "type": "i32", "value": "$world_height" },
        "random_seed": { "type": "u32" },
        "padding": { "type": "u32" },
        "padding2": { "type": "u32" },
        "padding3": { "type": "u32" }
      },
      "capacity": 1,
      "buffer_category": "input"
    },
    {
      "name": "Framebuffer",
      "struct": {
        "pixel": { "type": "u32" }
      },
      "capacity": "$display_width * $display_height",
      "buffer_category": "transient"
    }
  ],
  "pipeline": [
    {
      "name": "identity_step",
      "kernel": "identity",
      "depends_on": [],
      "consumes": ["EntityBuffer"],
      "produces": ["EntityBuffer"]
    }
  ],
  "render_kernel": "render_solid"
}
